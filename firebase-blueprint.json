{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "format": "email", "description": "The email of the user." },
        "photoURL": { "type": "string", "description": "The photo URL of the user." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The role of the user." }
      },
      "required": ["uid", "email"]
    },
    "Simulation": {
      "title": "Simulation",
      "description": "A social entrepreneurship simulation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["Running", "Review Required", "Paused", "Completed"] },
        "progress": { "type": "number" },
        "authorUid": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "authorUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/simulations/{simId}": {
      "schema": "Simulation",
      "description": "Collection of user simulation states."
    }
  }
}
